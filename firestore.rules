rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- LEGACY PATHS (read-only during migration; no new writes) ---
    match /saves/default {
      allow read, write: if false;
    }
    match /state/main {
      // Read only by the original owner so the app can offer one-time
      // migration into the new farm structure. No new writes anywhere.
      allow read: if request.auth != null
        && request.auth.token.email == 'twlakesfarm@gmail.com';
      allow write: if false;
    }
    match /users/{userId}/state/{stateDoc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // --- FARMS (multi-tenant) ---
    // A farm is a workspace. Membership is the email allowlist on the farm doc.
    // members[] contains the lower-cased emails of users who can read/write.
    match /farms/{farmId} {
      // Read/list: members only. Firestore evaluates this per doc, so client
      // queries with where('members','array-contains',email) will only return
      // farms the caller belongs to.
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.members;

      // Create: any signed-in user can create a farm, as long as they include
      // themselves in the initial members list.
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.auth.token.email in request.resource.data.members
        && request.resource.data.name is string
        && request.resource.data.currentYear is string;

      // Update: existing members only. Members can also adjust the members
      // list (invite/remove teammates).
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.members
        && request.resource.data.members is list
        && request.auth.token.email in request.resource.data.members; // can't kick yourself

      // Delete: blocked here; do via UI with explicit confirmation later.
      allow delete: if false;
    }

    // Per-year state under each farm. Membership is checked on the parent farm.
    match /farms/{farmId}/years/{year} {
      allow read, write: if request.auth != null
        && request.auth.token.email in
           get(/databases/$(database)/documents/farms/$(farmId)).data.members;
    }
  }
}
